{
  "name": "@kansei-link/mcp-server",
  "mcpName": "io.github.kansei-link/kansei-mcp-server",
  "version": "1.1.0",
  "description": "MCP intelligence layer for discovering and orchestrating Japanese SaaS MCP tools",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kansei-link-mcp": "dist/index.js",
    "kansei-link-mcp-http": "dist/http-server.js",
    "kansei-link-install-skill": "dist/bin/install-skill.js",
    "kansei-link-report-hook": "dist/bin/report-hook.js"
  },
  "files": [
    "dist",
    "src/data/services-seed.json",
    "src/data/recipes-seed.json",
    "src/data/api-guides-seed.json",
    "src/data/changelog-seed.json",
    "src/data/voices-seed.json",
    "src/data/github-issues-30d-tips.json",
    "src/data/github-issues-180d-tips.json",
    "src/data/recipes-new-75.json",
    "src/data/jp-watchlist.txt",
    ".well-known"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').mkdirSync('dist/skill',{recursive:true}); require('fs').copyFileSync('src/skill/SKILL.md','dist/skill/SKILL.md')\"",
    "start": "node dist/index.js",
    "start:http": "node dist/http-server.js",
    "seed": "node dist/db/seed.js",
    "test:jp-search": "tsx scripts/verify-jp-search.mts",
    "test:seed-merge": "tsx scripts/verify-seed-tag-merge.mts",
    "articles:auto": "node scripts/generate-articles-auto.mjs",
    "crawl:issues": "tsx src/crawler/mine-issues.ts --days 30",
    "crawl:registry": "tsx src/crawler/sync-registry.ts",
    "crawl:probe": "tsx src/crawler/health-probe.ts --limit 5000",
    "crawl:probe:quick": "tsx src/crawler/health-probe.ts --limit 200",
    "crawl:all": "npm run crawl:probe && npm run crawl:issues",
    "watch": "tsx src/crawler/watchdog.ts",
    "watch:report": "tsx src/crawler/watchdog.ts --report",
    "watch:fix": "tsx src/crawler/watchdog.ts --report --fix",
    "crawl:diff": "tsx src/crawler/registry-diff.ts",
    "crawl:diff:ingest": "tsx src/crawler/registry-diff.ts --ingest",
    "ops:cycle": "tsx src/crawler/ops-cycle.ts",
    "ops:quick": "tsx src/crawler/ops-cycle.ts --quick",
    "ops:dry": "tsx src/crawler/ops-cycle.ts --dry",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "japanese-saas",
    "agent-engine-optimization",
    "aeo",
    "kansei-link"
  ],
  "author": "Synapse Arrows PTE. LTD.",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.7.0",
    "express": "^5.2.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "stripe": "^22.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
