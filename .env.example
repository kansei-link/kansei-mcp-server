# KanseiLink MCP Server — Environment Variables
# Copy to .env and fill in your values.

# ─── Server ───
PORT=3000
KANSEI_HOST=0.0.0.0
KANSEI_PUBLIC_URL=https://kansei-link.com

# ─── App deep-link (A21 — MCP "exit" / data-circulation entry point) ───
# Canonical KanseiLINK app/deep-link injected into tool responses (_meta.kansei_link).
# Placeholders until the official app-URL design is finalized; code falls back to these defaults.
# KANSEI_APP_BASE_URL=https://kansei-link.com/app
# KANSEI_DEEP_LINK_SCHEME=kanseilink

# ─── Database ───
# KANSEI_DB_PATH=./data/kansei.db   # default: ./data/kansei.db

# ─── Stripe Billing ───
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — create in Stripe Dashboard > Products
STRIPE_PRICE_PRO_MONTHLY=price_...    # Pro plan: $19/mo
STRIPE_PRICE_PRO_ANNUAL=price_...     # Pro plan: $149/yr
STRIPE_PRICE_TEAM=price_...           # Team plan: $149/mo per service

# ─── Auth & Tier Enforcement ───
# Per-email access tokens (web sign-in). Optional — falls back to
# STRIPE_WEBHOOK_SECRET, then CRAWLER_SECRET. Set explicitly to decouple
# token rotation from webhook secret rotation.
# ACCESS_TOKEN_SECRET=

# Magic-link login email delivery (https://resend.com). Without this the
# server logs the sign-in link to stdout instead of emailing it (operator
# can deliver it manually from Railway logs).
# RESEND_API_KEY=
# EMAIL_FROM=KanseiLink <login@kansei-link.com>

# Test-only: echo magic links in the /api/auth/request-link response.
# NEVER enable in production.
# KANSEI_AUTH_ECHO=1

# ─── Client-side (users of npx @kansei-link/mcp-server) ───
# Paid subscribers: set the API key issued at
# https://kansei-link.com/subscription/login.html to unlock premium fields.
# KANSEI_API_KEY=kl_...
# Override the validation endpoint (self-hosting / staging):
# KANSEI_API_BASE=https://kansei-link-mcp-production-b054.up.railway.app

# ─── Daily Intelligence Loop (crawler + refresh + snapshot + drift) ───
# Generate with: openssl rand -hex 32
# Required by POST /admin/run-crawler
CRAWLER_SECRET=

# GitHub token — increases rate limit from 60/hr to 5000/hr
GITHUB_TOKEN=

# Anthropic key — enables Claude Sonnet classification of new candidates
# (falls back to regex heuristic if unset)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ─── AI Citation Audit (scripts/ai-answer-audit.mjs) ───
# Measures whether ChatGPT / Perplexity / Gemini cite KanseiLink (KPI: AI引用率).
# Each engine is optional — the audit runs only the engines whose key is set.
# Run: node --env-file=.env scripts/ai-answer-audit.mjs <battery.json> --engines openai,gemini,perplexity
OPENAI_API_KEY=          # https://platform.openai.com/api-keys  (⚠️ 課金切れ→要再課金)
PERPLEXITY_API_KEY=      # https://www.perplexity.ai/settings/api
GEMINI_API_KEY=          # https://aistudio.google.com/apikey
# Optional model overrides (defaults: gpt-5 / sonar / gemini-2.5-flash / claude-opus-4-8)
# OPENAI_AUDIT_MODEL=
# PERPLEXITY_AUDIT_MODEL=
# GEMINI_AUDIT_MODEL=
# ANTHROPIC_AUDIT_MODEL=

# ─── GA4 (site analytics) ───
# Not an env var — the measurement ID (G-XXXXXXXXXX) goes into the site <head> as a gtag snippet.
# Set it in public/ pages (ask Claude to inject once you have the ID from GA > Admin > Data Streams).
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX   # reference only
