# KanseiLink MCP Server — Environment Variables
# Copy to .env and fill in your values.

# ─── Server ───
PORT=3000
KANSEI_HOST=0.0.0.0
KANSEI_PUBLIC_URL=https://kansei-link.com

# ─── Database ───
# KANSEI_DB_PATH=./data/kansei.db   # default: ./data/kansei.db

# ─── Stripe Billing ───
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — create in Stripe Dashboard > Products
STRIPE_PRICE_PRO_MONTHLY=price_...    # Pro plan: $19/mo
STRIPE_PRICE_PRO_ANNUAL=price_...     # Pro plan: $149/yr
STRIPE_PRICE_TEAM=price_...           # Team plan: $149/mo per service

# ─── Daily Intelligence Loop (crawler + refresh + snapshot + drift) ───
# Generate with: openssl rand -hex 32
# Required by POST /admin/run-crawler
CRAWLER_SECRET=

# GitHub token — increases rate limit from 60/hr to 5000/hr
GITHUB_TOKEN=

# Anthropic key — enables Claude Sonnet classification of new candidates
# (falls back to regex heuristic if unset)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
