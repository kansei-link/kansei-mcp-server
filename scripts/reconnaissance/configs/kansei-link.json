{
  "$schema_version": 1,
  "_doc": "Reconnaissance config for KanseiLINK self-monitoring. References the existing HEALTH.json at repo root.",

  "product": "KanseiLink",
  "schedule": "0 0 * * *",
  "timezone": "UTC",
  "tier": "B-alpha",

  "monitors": {
    "health": {
      "enabled": true,
      "urls": [
        "https://kansei-link.com",
        "https://kansei-link.com/dashboard/",
        "https://kansei-link.com/changelog.html",
        "https://kansei-link-mcp-production.up.railway.app/health",
        "https://kansei-link-mcp-production.up.railway.app/api/dashboard/freshness",
        "https://kansei-link-mcp-production.up.railway.app/api/dashboard/rankings?limit=10",
        "https://kansei-link-mcp-production.up.railway.app/api/dashboard/recipes",
        "https://kansei-link-mcp-production.up.railway.app/api/dashboard/changelog?limit=10",
        "https://linksee-site.vercel.app"
      ],
      "_excluded_urls_pending_method_support": [
        "https://linksee-site.vercel.app/api/waitlist (POST-only — Tier B-β: add method-aware health monitor)"
      ],
      "expected_status": 200,
      "timeout_ms": 10000
    },

    "snapshot": {
      "enabled": true,
      "_note": "Tier B-β. Rolling baseline (yesterday vs today). Diff > threshold raises warning/critical.",
      "urls": [
        "https://kansei-link.com",
        "https://kansei-link.com/dashboard/",
        "https://kansei-link.com/changelog.html"
      ],
      "diff_threshold_pct": 5,
      "viewport": { "width": 1280, "height": 800 },
      "timeout_ms": 30000,
      "ignore_selectors": [
        "[data-testid='timestamp']",
        ".updated-at"
      ]
    },

    "agent_voice_probe": {
      "enabled": true,
      "_note": "Tier B-γ. KanseiLINK has no chat feature, so we use API contract probes — assert that public dashboard APIs respond with non-empty expected fields. Catches schema drift that urls_must_200 cannot.",
      "timeout_ms": 15000,
      "probes": [
        {
          "name": "dashboard freshness reports services_total >= 1",
          "request": {
            "method": "GET",
            "url": "https://kansei-link-mcp-production.up.railway.app/api/dashboard/freshness"
          },
          "expectations": {
            "status": 200,
            "json_paths": [
              { "path": "services_total", "type": "number", "min": 1 }
            ]
          },
          "spec_ref": "HEALTH.json#baselines.railway_services_total"
        },
        {
          "name": "dashboard rankings returns >=1 service with id+category+axr_grade",
          "request": {
            "method": "GET",
            "url": "https://kansei-link-mcp-production.up.railway.app/api/dashboard/rankings?limit=10"
          },
          "expectations": {
            "status": 200,
            "json_paths": [
              { "path": "services", "type": "array", "min": 1 },
              { "path": "services[0].id", "type": "string" },
              { "path": "services[0].category", "type": "string" },
              { "path": "services[0].axr_grade", "type": "string" }
            ]
          }
        },
        {
          "name": "dashboard recipes returns >=1 recipe with id+goal",
          "request": {
            "method": "GET",
            "url": "https://kansei-link-mcp-production.up.railway.app/api/dashboard/recipes"
          },
          "expectations": {
            "status": 200,
            "json_paths": [
              { "path": "recipes", "type": "array", "min": 1 },
              { "path": "recipes[0].id", "type": "string" },
              { "path": "recipes[0].goal", "type": "string" }
            ]
          }
        }
      ]
    }
  },

  "report_to": [
    {
      "destination": "data/reconnaissance/reports/{date}.md",
      "method": "file_write"
    }
  ],

  "urgency_rules": {
    "critical": [
      "health.url returns non-2xx",
      "health.url times out"
    ],
    "warning": [
      "response time > 3000ms"
    ],
    "info": []
  }
}
