{
  "$schema_version": 1,
  "_doc": "Reconnaissance config for CardWize. Repo: https://github.com/michielinksee/Card_Navi",

  "product": "CardWize",
  "schedule": "0 0 * * *",
  "timezone": "UTC",
  "tier": "B-alpha",

  "monitors": {
    "health": {
      "enabled": true,
      "urls": [
        "https://card-nabi.vercel.app",
        "https://card-nabi.vercel.app/cards",
        "https://card-nabi.vercel.app/wallet",
        "https://card-nabi.vercel.app/diagnosis"
      ],
      "expected_status": 200,
      "timeout_ms": 10000
    },

    "snapshot": {
      "enabled": true,
      "_note": "Tier B-β. Rolling baseline. /cards skipped pending route fix (returned 404 in Day 1 health probe).",
      "urls": [
        "https://card-nabi.vercel.app",
        "https://card-nabi.vercel.app/wallet",
        "https://card-nabi.vercel.app/diagnosis"
      ],
      "diff_threshold_pct": 5,
      "viewport": { "width": 1280, "height": 800 },
      "timeout_ms": 30000,
      "ignore_selectors": [
        "[data-testid='timestamp']",
        ".loading-skeleton"
      ]
    },

    "agent_voice_probe": {
      "enabled": false,
      "_note": "Tier B-beta: probe diagnosis flow with sample inputs"
    }
  },

  "report_to": [
    {
      "destination": "data/reconnaissance/reports/{date}.md",
      "method": "file_write"
    }
  ],

  "urgency_rules": {
    "critical": [
      "health.url returns non-2xx"
    ],
    "warning": [
      "response time > 3000ms"
    ],
    "info": []
  }
}
